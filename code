};

// saisir produit
void produit(struct produit *p){
    printf("donner le nom du produit: ");
    scanf("%s", p->nom);

    printf("donner quantité: ");
    scanf("%d", &p->qt);

    printf("donner le prix d'achat: ");
    scanf("%f", &p->pa);

    printf("donner le prix de vente: ");
    scanf("%f", &p->pv);
}

// vente
void vente(struct produit p, struct vente *v){
    printf("donner la quantité vendue: ");
    scanf("%d", &v->qtv);

    if(v->qtv > p.qt){
        printf("stock insuffisant !\n");
        v->qtv = 0;
    }

    v->totale = v->qtv * p.pv;
    v->benefice = v->qtv * (p.pv - p.pa);
}

// facture
void facture(struct facture *f){
    produit(&f->p);
    vente(f->p, &f->v);

    f->tt = f->v.totale;
    f->ben = f->v.benefice;

    printf("\n--- FACTURE ---\n");
    printf("Produit: %s\n", f->p.nom);
    printf("Totale: %.2f\n", f->tt);
    printf("Benefice: %.2f\n", f->ben);
}
