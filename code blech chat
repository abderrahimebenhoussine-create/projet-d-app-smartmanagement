#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// ===== STRUCT =====
typedef struct produit {
    char nom[50];
    int qt;
    float pa;
    float pv;
    struct produit *suiv;
} produit;

// ===== RECHERCHE =====
produit* chercher(produit *tete, char nom[]) {
    produit *p = tete;

    while (p != NULL) {
        if (strcmp(p->nom, nom) == 0) {
            return p;
        }
        p = p->suiv;
    }

    return NULL;
}

// ===== AJOUTER PRODUIT =====
produit* ajouter(produit *tete) {
    produit *nv = malloc(sizeof(produit));

    if (nv == NULL) {
        printf("Erreur allocation memoire !\n");
        return tete;
    }

    printf("Nom: ");
    scanf(" %49[^\n]", nv->nom);

    if (chercher(tete, nv->nom) != NULL) {
        printf("Ce produit existe deja !\n");
        free(nv);
        return tete;
    }

    printf("Quantite: ");
    scanf("%d", &nv->qt);

    printf("Prix achat: ");
    scanf("%f", &nv->pa);

    printf("Prix vente: ");
    scanf("%f", &nv->pv);

    nv->suiv = tete;
    tete = nv;

    printf("Produit ajoute avec succes.\n");

    return tete;
}

// ===== AFFICHER STOCK =====
void afficher(produit *tete) {
    produit *p = tete;

    if (p == NULL) {
        printf("\nStock vide !\n");
        return;
    }

    printf("\n========== STOCK ==========\n");

    while (p != NULL) {
        printf("Nom: %s | Quantite: %d | Prix achat: %.2f | Prix vente: %.2f\n",
               p->nom, p->qt, p->pa, p->pv);
        p = p->suiv;
    }
}

// ===== MODIFIER PRODUIT =====
void modifier(produit *tete) {
    char nom[50];

    printf("Nom produit a modifier: ");
    scanf(" %49[^\n]", nom);

    produit *p = chercher(tete, nom);

    if (p == NULL) {
        printf("Produit non trouve !\n");
        return;
    }

    printf("Nouvelle quantite: ");
    scanf("%d", &p->qt);

    printf("Nouveau prix achat: ");
    scanf("%f", &p->pa);

    printf("Nouveau prix vente: ");
    scanf("%f", &p->pv);

    printf("Produit modifie avec succes.\n");
}

// ===== SUPPRIMER PRODUIT =====
produit* supprimer(produit *tete) {
    char nom[50];

    printf("Nom produit a supprimer: ");
    scanf(" %49[^\n]", nom);

    produit *p = tete;
    produit *prec = NULL;

    while (p != NULL && strcmp(p->nom, nom) != 0) {
        prec = p;
        p = p->suiv;
    }

    if (p == NULL) {
        printf("Produit non trouve !\n");
        return tete;
    }

    if (prec == NULL) {
        tete = p->suiv;
    } else {
        prec->suiv = p->suiv;
    }

    free(p);

    printf("Produit supprime avec succes.\n");

    return tete;
}

// ===== VENTE =====
void vente(produit *tete) {
    char nom[50];
    int qtv;

    printf("Nom produit: ");
    scanf(" %49[^\n]", nom);

    produit *p = chercher(tete, nom);

    if (p == NULL) {
        printf("Produit non trouve !\n");
        return;
    }

    printf("Quantite vendue: ");
    scanf("%d", &qtv);

    if (qtv <= 0) {
        printf("Quantite invalide !\n");
        return;
    }

    if (qtv > p->qt) {
        printf("Stock insuffisant ! Quantite disponible: %d\n", p->qt);
        return;
    }

    float total = qtv * p->pv;
    float benefice = qtv * (p->pv - p->pa);

    p->qt -= qtv;

    printf("\n========== FACTURE ==========\n");
    printf("Produit: %s\n", p->nom);
    printf("Quantite vendue: %d\n", qtv);
    printf("Prix unitaire: %.2f\n", p->pv);
    printf("Total: %.2f\n", total);
    printf("Benefice: %.2f\n", benefice);
    printf("Quantite restante: %d\n", p->qt);
    printf("=============================\n");
}

// ===== SAUVEGARDER DANS FICHIER =====
void sauvegarder(produit *tete) {
    FILE *f = fopen("stock.dat", "wb");

    if (f == NULL) {
        printf("Erreur ouverture fichier !\n");
        return;
    }

    produit *p = tete;

    while (p != NULL) {
        fwrite(p, sizeof(produit), 1, f);
        p = p->suiv;
    }

    fclose(f);

    printf("Stock sauvegarde avec succes.\n");
}

// ===== CHARGER DEPUIS FICHIER =====
produit* charger() {
    FILE *f = fopen("stock.dat", "rb");
    produit *tete = NULL;

    if (f == NULL) {
        return NULL;
    }

    produit temp;

    while (fread(&temp, sizeof(produit), 1, f) == 1) {
        produit *nv = malloc(sizeof(produit));

        if (nv == NULL) {
            printf("Erreur allocation memoire pendant le chargement !\n");
            fclose(f);
            return tete;
        }

        strcpy(nv->nom, temp.nom);
        nv->qt = temp.qt;
        nv->pa = temp.pa;
        nv->pv = temp.pv;

        nv->suiv = tete;
        tete = nv;
    }

    fclose(f);

    return tete;
}

// ===== LIBERER MEMOIRE =====
void liberer(produit *tete) {
    produit *p;

    while (tete != NULL) {
        p = tete;
        tete = tete->suiv;
        free(p);
    }
}

// ===== MAIN =====
int main() {
    produit *stock = charger();
    int choix;

    do {
        printf("\n========== MENU ==========\n");
        printf("1. Ajouter produit\n");
        printf("2. Afficher stock\n");
        printf("3. Modifier produit\n");
        printf("4. Vente\n");
        printf("5. Supprimer produit\n");
        printf("6. Sauvegarder\n");
        printf("0. Quitter\n");
        printf("==========================\n");

        printf("Choix: ");
        scanf("%d", &choix);

        if (choix == 1) {
            stock = ajouter(stock);
        }
        else if (choix == 2) {
            afficher(stock);
        }
        else if (choix == 3) {
            modifier(stock);
        }
        else if (choix == 4) {
            vente(stock);
        }
        else if (choix == 5) {
            stock = supprimer(stock);
        }
        else if (choix == 6) {
            sauvegarder(stock);
        }
        else if (choix == 0) {
            sauvegarder(stock);
            liberer(stock);
            printf("Sauvegarde automatique effectuee.\n");
            printf("Bye!\n");
        }
        else {
            printf("Choix invalide !\n");
        }

    } while (choix != 0);

    return 0;
}
